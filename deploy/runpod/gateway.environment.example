NODE_ENV=production
PORT=8080
LOG_LEVEL=info
GATEWAY_API_KEYS={{ RUNPOD_SECRET_gateway_client_keys }}
ALLOWED_TEXT_MODELS=portfolio-text-model
VLLM_BASE_URL=http://REDACTED_POD_ID.runpod.internal:8000/v1
VLLM_API_KEY={{ RUNPOD_SECRET_vllm_api_key }}
VLLM_MODEL_ID=portfolio-text-model
IMAGE_WORKER_BASE_URL=http://REDACTED_IMAGE_POD_ID.runpod.internal:9000
IMAGE_WORKER_API_KEY={{ RUNPOD_SECRET_image_worker_api_key }}
REQUEST_TIMEOUT_MS=45000
MAX_COMPLETION_TOKENS=2048
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
