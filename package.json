{
  "name": "node-typescript-integration-demo",
  "version": "1.0.0",
  "description": "Sanitized portfolio demo of a resilient Node.js and TypeScript integration pipeline.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "csv-stringify": "^6.5.2",
    "express": "^4.21.2",
    "fast-xml-parser": "^4.5.3",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.19.0",
    "globals": "^15.14.0",
    "prettier": "^3.5.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0",
    "vitest": "^3.0.5"
  }
}
